{
  "name": "forge",
  "version": "0.2.0",
  "description": "Idea machine for one human across many side projects. Autonomous multi-agent system.",
  "type": "module",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "bin": {
    "forge": "./bin/forge.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "forge-ui"
  ],
  "scripts": {
    "build": "tsc && npm run build --workspace=forge-ui",
    "build:orchestrator": "tsc",
    "build:ui": "npm run build --workspace=forge-ui",
    "build:watch": "tsc --watch",
    "test": "node --test --experimental-strip-types orchestrator/*.test.ts orchestrator/phases/*.test.ts orchestrator/studio/*.test.ts cli/*.test.ts loops/ralph/*.test.ts loops/_adapters/*.test.ts loops/_adapters/**/*.test.ts skills/*/*.test.ts scripts/*.test.ts",
    "lint": "echo 'TODO: pick a linter; the toolchain stays minimal until a need appears'",
    "forge": "node --experimental-strip-types orchestrator/cli.ts",
    "forge:brain:lint": "node --experimental-strip-types cli/brain-lint.ts",
    "forge:brain:index": "node --experimental-strip-types cli/brain-index.ts",
    "ui:journey": "node scripts/e2e-journey.mjs",
    "ui:deadpaths": "node scripts/e2e-deadpaths.mjs",
    "verify:cycle": "node scripts/verify-cycle.mjs",
    "test:ui": "npm run test --workspace=forge-ui"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.2.0",
    "proper-lockfile": "^4.1.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/ws": "^8.18.1",
    "playwright-core": "^1.60.0",
    "typescript": "^5.6.0"
  }
}
