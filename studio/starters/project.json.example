// .forge/project.json — the forge↔project contract for ONE managed project.
//
// Copy this to `<your-project>/.forge/project.json`, strip the comments (this
// file uses // comments for annotation; the real file must be strict JSON),
// and fill in every placeholder. It is the single declaration forge reads to
// develop a project unattended. Language-agnostic: the same shape onboards a
// UI app, an HTTP API, a library, a CLI, or an infra provider — only the
// command strings differ.
//
// Validate with:  forge preflight <project-id>
// Full spec:      docs/forge-project-contract.md
{
  // ── Identity (Studio face) ────────────────────────────────────────────────

  // name (required): human-readable project name shown in Studio.
  "name": "<project name>",

  // northStar (required, <= 140 chars): the project's primary objective in one
  // line. Every planning prompt is anchored on this.
  "northStar": "<one-line statement of what this project is for>",

  // instructions (required, non-empty): standing rules injected into every
  // project-manager prompt — conventions a developer agent must always honour.
  "instructions": "<standing instructions; e.g. 'TDD; never edit generated files; see AGENTS.md'>",

  // demoProcess (required: >= 1 capture + >= 1 verify step): the typed demo
  // recipe the unifier follows. kind is one of capture | verify | present.
  "demoProcess": [
    { "kind": "capture", "text": "<capture the before state of the change>" },
    { "kind": "verify",  "text": "<run the quality gate / hit the resource to prove the change>" }
    // , { "kind": "present", "text": "<optional: how to present the evidence>" }
  ],

  // skills (optional): per-project skill slugs the agents may compose.
  "skills": [],

  // kb (optional): the knowledge-base id this project's brain binds to, or null.
  "kb": null,

  // ── Test process (C1 local HARD; C1b ci HARD once declared; C7 acceptance
  //     HARD only when required=true) ─────────────────────────────────────

  // testProcess.local (required): the fast per-WI gate — ONE deterministic
  // command, green at HEAD, that proves a change is good. Argv array (no
  // shell pipes/&&/;). Must be fast and not require live external systems.
  // Examples by project type:
  //   library/api:   ["npm","test"]      ["go","test","./..."]    ["pytest","-q"]
  //   infra/provider:["go","test","./..."]  (unit tier; live tier via testProcess.acceptance)
  // `cmd` may be OMITTED here if the `.forge/quality_gate_cmd` sidecar (a
  // single whitespace-separated command line) declares it instead — the
  // loader single-sources from the sidecar when the JSON omits
  // testProcess.local.cmd; when both are present, the JSON wins (explicit
  // override).
  "testProcess": {
    "local": {
      "cmd": ["<test-runner>", "<args>"]
      // , "timeoutMs": 1800000   // overrides the 30-min default; FORGE_GATE_TIMEOUT_MS still wins
    }

    // ci (optional, C1b — HARD shape once declared): the full CI command,
    // when testProcess.local is a strict subset of it. Run DIRECTLY
    // (operator-trusted) as the final delivery gate before a PR opens.
    // , "ci": {
    //   "cmd": ["<full-ci-command>", "<args>"],
    //   "fixCmd": ["<auto-formatter-command>", "<args>"],
    //   "unsetEnv": ["<LIVE_TEST_TRIGGER_VAR>"],
    //   "timeoutMs": 1200000
    // }

    // acceptance (optional, C7 — HARD only when required=true): declare this
    // ONLY if the project has a live/external acceptance tier (e.g. a
    // Terraform provider hitting a real API). Omit it entirely otherwise.
    //   match       — substring identifying a live-acceptance gate in a WI's
    //                 quality_gate_cmd (e.g. "TF_ACC=1").
    //   required    — when true, the PM phase hard-fails a cycle unless >= 1
    //                 WI carries a matching live gate.
    //   requiresEnv — every env var a matching live gate needs to actually
    //                 run against the live system (e.g.
    //                 ["TF_ACC","AZDO_ORG_SERVICE_URL"]). These are looked up
    //                 in the project's gitignored secrets.env (see
    //                 docs/getting-started.md). If a matching gate runs with
    //                 one of these unset, the dev-loop ERRORS the gate (no
    //                 false pass).
    // , "acceptance": {
    //   "match": "<live-gate token, e.g. TF_ACC=1>",
    //   "required": true,
    //   "requiresEnv": ["<ENV_VAR_1>", "<ENV_VAR_2>"]
    // }
  },

  // ── Demo shape (DEMO, advisory) ───────────────────────────────────────────

  // demo: how a change is demonstrated. shape is one of
  //   harness | cli-diff | artifact | browser | none.
  // command (required unless shape=none): argv producing the demo evidence.
  "demo": {
    "shape": "harness",
    "command": ["<demo-command>", "<args>"]
    // browser shape also needs:  "preview_command": ["<dev-server>", "<args>"]
  },

  // ── Committed-artifact root (C4) ──────────────────────────────────────────

  // artifactRoot (optional, default "."): where the project's committed forge
  // artifacts live — its Brain 3 (<artifactRoot>/brain/profile.md) + history.
  // "." keeps brain/ at the project root.
  "artifactRoot": "."

  // releaseProcess (optional, C10): opt into the release flow. Declaring it
  // turns on (1) an in-cycle DRAFT changelog (every WI's standing ACs), (2) a
  // post-approval pre-merge finaliser (semver bump + finalised changelog + the
  // pre-merge steps below + optional version bump, committed to the PR branch),
  // and (3) a CI release on merge. Forge SHIPS the release CI workflow
  // (studio/starters/release-workflow.yml.example) but NEVER runs tag/publish —
  // that is CI's job. A project without this block is unchanged.
  // , "releaseProcess": {
  //   "changelogPath": "CHANGELOG.md",
  //   "versionFile": "<path holding the version, e.g. package.json | VERSION>",
  //   "docsDir": "docs",
  //   "steps": [
  //     { "kind": "changelog", "phase": "in-cycle",  "text": "draft an Unreleased entry per WI" },
  //     { "kind": "docs",      "phase": "pre-merge", "text": "regenerate reference docs", "command": ["<doc-gen>", "<args>"] },
  //     { "kind": "version",   "phase": "pre-merge", "text": "bump the version file to the computed semver" }
  //   ]
  // }
}
