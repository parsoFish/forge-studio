node_modules/
dist/

# Ephemeral diagnostic scripts (e.g., one-off probes / browser drives).
# Convention: prefix with .tmp- in scripts/ for things that are useful
# locally but shouldn't churn the tree.
scripts/.tmp-*

# forge-ui (Next.js workspace) build artefacts
forge-ui/.next/
forge-ui/out/
forge-ui/tsconfig.tsbuildinfo
forge-ui/next-env.d.ts
# forge-ui/.demo-shots/ PNG frame galleries + HIGHLIGHTS/index are version-tracked
# (the watchable demo + DOM-as-metrics regression artifact). The .webm VIDEOS are
# NOT — they are regenerable and too large for git (a verify cycle.webm hit 110MB,
# past GitHub's 100MB cap). Regenerate locally via `npm run ui:journey` / `verify:cycle`.
forge-ui/.demo-shots/**/*.webm

# Runtime state — not source. Ignore contents but keep .gitkeep so structure
# is preserved in git.
_logs/*
!_logs/.gitkeep
!_logs/README.md
_queue/pending/*
!_queue/pending/.gitkeep
_queue/in-flight/*
!_queue/in-flight/.gitkeep
_queue/ready-for-review/*
!_queue/ready-for-review/.gitkeep
_queue/done/*
!_queue/done/.gitkeep
_queue/failed/*
!_queue/failed/.gitkeep

# Per-run benchmark output is runtime, not source
benchmarks/*/results/
benchmarks/*/results-negatives/
benchmarks/*/results-judged/

# Bench-fixture runtime debris (Python compile cache; Ralph workspace artifacts
# the agent leaves behind if a run leaks outside its tempdir; reviewer demo
# bundles ditto). Seeds should only contain source files, tests, and the WI
# spec.
benchmarks/*/fixtures/**/__pycache__/
benchmarks/*/fixtures/**/.pytest_cache/
benchmarks/*/fixtures/**/AGENT.md
benchmarks/*/fixtures/**/fix_plan.md
benchmarks/*/fixtures/**/PROMPT.md
benchmarks/*/fixtures/**/.forge/demos/
benchmarks/*/fixtures/**/.forge/pr-description.md

# Managed projects are auto-discovered, not committed to forge
projects/*
!projects/README.md
!projects/.gitkeep

# Worktrees the scheduler creates
_worktrees/

# Unifier scratchpad + DEMO bundle directories — these belong to a
# worktree, but occasionally leak to the forge root when a worktree's
# fast-forward into main carries gitignored-elsewhere paths. Pin them
# at the root so the leak doesn't recur.
/.forge/
/demo/

# Review/audit output — runtime artefact, not source
_review/

# Forge's own runtime config (per-machine)
forge.config.json

# Secrets — never commit. zep.env holds the Zep Cloud API key (KB backend);
# the catch-all guards any other local credential files.
zep.env
secrets.env
*.env
!*.env.example

# Editor / OS noise
.DS_Store
.vscode/
.idea/
# Local Claude Code state (settings, transcripts) is per-machine noise — but
# .claude/commands/ holds the operator-facing slash-command SOURCE (the three
# human-interaction moments; Phase 7 / US-3.1) and IS committed.
.claude/*
!.claude/commands/
*.swp
*.swo
*~

# Obsidian vault config (per-user)
brain/.obsidian/

# Logs from local runs
*.log
npm-debug.log*
